# ══════════════════════════════════════════════════════════
# SecNet Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Every integration is optional. Leave a section commented
# out and that tab/panel will hide automatically in the UI.
# ══════════════════════════════════════════════════════════

# ── Feature Flags ─────────────────────────────────────────
# Set to false to disable a data source entirely.
# When disabled, the backend returns empty data and the
# frontend hides the corresponding tab or section.
# Default: all true. Only uncomment what you want OFF.
#
# ENABLE_CROWDSEC=false
# ENABLE_UNIFI=false
# ENABLE_PROXMOX=false
# ENABLE_LOKI=false
# ENABLE_PROMETHEUS=false
# ENABLE_OPENAI=false
# ENABLE_WORKSTATIONS=false

# ── CrowdSec ─────────────────────────────────────────────
# Local API bouncer. Powers the Security tab: ban tracking,
# attacker geo-map, threat intel, attack breakdown.
#
# CROWDSEC_URL=http://your-crowdsec-host:8080
# CROWDSEC_API_KEY=your-bouncer-api-key
#
# Machine auth for the alerts endpoint (bouncer keys only get decisions).
# Register on CrowdSec host: cscli machines add secnet-dashboard --password "YourPassword" --force
# CROWDSEC_MACHINE_ID=secnet-dashboard
# CROWDSEC_MACHINE_PASSWORD=YourPassword

# ── Loki ──────────────────────────────────────────────────
# Log aggregation. Feeds the UniFi events and Traefik logs
# panels in the Logs tab.
#
# LOKI_URL=http://your-loki-host:3100

# ── Prometheus ────────────────────────────────────────────
# Metrics. Powers the ban timeline, event rate charts, and
# summary stat cards (LAPI requests, bucket events, parser hits).
#
# PROMETHEUS_URL=http://your-prometheus-host:9090

# ── UniFi ─────────────────────────────────────────────────
# UniFi controller (UDM Pro, Cloud Key, etc). Powers the
# Network tab: AP health, switch ports, client monitoring.
#
# UNIFI_URL=https://your-unifi-controller
# UNIFI_USERNAME=your-username
# UNIFI_PASSWORD=your-password

# ── Proxmox ──────────────────────────────────────────────
# Proxmox VE API. Powers the Infrastructure tab: hypervisor
# CPU/RAM, VM and container inventory. Supports up to 3 nodes.
#
# PVE1_URL=https://your-pve1:8006
# PVE1_TOKEN=user@pam!tokenid=your-token-secret
# PVE2_URL=https://your-pve2:8006
# PVE2_TOKEN=user@pam!tokenid=your-token-secret
# PVE3_URL=https://your-pve3:8006
# PVE3_TOKEN=user@pam!tokenid=your-token-secret

# ── Workstation Agents ────────────────────────────────────
# Shared secret between the SecNet server and workstation
# agents. Pick any string — just make sure it matches what
# you enter in the agent installer on each machine.
#
# The agents POST to /api/workstations/report with this key
# in the X-Agent-Key header. If it doesn't match, the server
# returns 403.
#
# Generate one however you like, e.g.:
#   python3 -c "import secrets; print(f'secnet-ws-{secrets.token_hex(12)}')"
#
# WORKSTATION_AGENT_KEY=secnet-ws-your-random-key-here

# ── AI / HelpDesk ────────────────────────────────────────
# OpenAI API key for the AI chat assistant. The assistant
# knows your dashboard context and answers security questions.
# Gate-locked questions require the gate code below.
#
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4.1-mini

# ── Auth Gate ─────────────────────────────────────────────
# Protects sensitive operations: network scans, AI chat with
# infrastructure context. Rate-limited: 5 attempts per minute.
#
# SECURITY_GATE_CODE=your-gate-code

# ── Tuning (optional) ────────────────────────────────────
# GEOIP_PROVIDER=ip-api
# GEOIP_RATE_LIMIT=45
# POLL_INTERVAL=15

# ── Database ──────────────────────────────────────────────
# Path inside the container. Mapped via docker volume.
# SECNET_DB=/data/secnet.db
